{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "query-filter/filter-date-range",
  "version": "0.1.0",
  "title": "Filter: Date range",
  "category": "theme",
  "icon": "calendar",
  "description": "Filter by post published date (Y-m-d). Default index key is post_date; override via hook for custom sources.",
  "parent": ["query-filter/filter-container"],
  "usesContext": ["query-filter/queryId"],
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": { "margin": true, "padding": true }
  },
  "attributes": {
    "filterName": { "type": "string", "default": "post_date" },
    "label": { "type": "string", "default": "" },
    "showLabel": { "type": "boolean", "default": true }
  },
  "textdomain": "query-filter",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
