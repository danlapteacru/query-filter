{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "query-filter/filter-range",
  "version": "0.1.0",
  "title": "Filter: Number range",
  "category": "theme",
  "icon": "leftright",
  "description": "Min/max numeric filter (register Query_Filter_Filter_Range + meta via query_filter/indexer/register_filters).",
  "parent": ["query-filter/filter-container"],
  "usesContext": ["query-filter/queryId"],
  "supports": {
    "html": false,
    "interactivity": true,
    "spacing": { "margin": true, "padding": true }
  },
  "attributes": {
    "filterName": { "type": "string", "default": "" },
    "label": { "type": "string", "default": "" },
    "showLabel": { "type": "boolean", "default": true },
    "step": { "type": "number", "default": 1 },
    "inputMin": { "type": "string", "default": "" },
    "inputMax": { "type": "string", "default": "" }
  },
  "textdomain": "query-filter",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "render": "file:./render.php"
}
